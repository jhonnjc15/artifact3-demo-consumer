{
  "environment": "dev",
  "glue_jobs": {
    "demo_print_parameters": {
      "enabled": true,
      "job_name": "glue-demo-print-parameters-dev",
      "description": "Glue Job demo que imprime default arguments y una tabla creada en memoria",
      "script_local_path": "./src/libs/demo_print_parameters.py",
      "script_s3_key": "glue/jobs/dev/demo_print_parameters.py",
      "glue_version": "4.0",
      "python_version": "3",
      "worker_type": "G.1X",
      "number_of_workers": 2,
      "timeout": 30,
      "max_retries": 0,
      "default_arguments": {
        "--demo_env": "dev",
        "--demo_owner": "data-engineering",
        "--demo_table": "tabla_demo_parametros"
      }
    }
  },
  "athena": {
    "enabled": true,
    "sql_path": "./src/sql/create_table.sql",
    "s3_location": "s3://bronze-1358-0891-8691/COMERCIAL/ybwds_copa_brz/",
    "table_type": "EXTERNAL_TABLE",
    "parameters": {
      "projection.enabled": "true",
      "projection.ingestion_date.type": "date",
      "projection.ingestion_date.range": "2020-01-01,NOW",
      "projection.ingestion_date.format": "yyyy-MM-dd",
      "storage.location.template": "s3://bronze-1358-0891-8691/COMERCIAL/ybwds_copa_brz/ingestion_date=${ingestion_date}/"
    }
  },
  "lambda": {
    "enabled": true,
    "function_name": "lambda-demo-dev",
    "description": "Lambda demo para probar el módulo",
    "source_path": "./src/lambda",
    "handler": "main.handler",
    "runtime": "python3.11",
    "timeout": 30,
    "memory_size": 256
  }
}