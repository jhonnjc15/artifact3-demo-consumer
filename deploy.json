{
  "databases": {
    "demo": {
      "enabled": true,
      "enabled_environments": ["dev"],
      "name": "db_demo",
      "mode": "existing"
    }
  },
  "glue_jobs": {
    "demo_print_parameters": {
      "enabled": true,
      "enabled_environments": ["dev"],
      "job_name": "glue-demo-print-parameters",
      "description": "Glue Job demo que imprime default arguments y una tabla creada en memoria",
      "script_local_path": "./src/libs/demo_print_parameters.py",
      "glue_version": "4.0",
      "python_version": "3",
      "worker_type": "G.1X",
      "number_of_workers": 2,
      "timeout": 30,
      "max_retries": 0,
      "athena_table_key": "ybwds_copa_brz",
      "validations": {
        "enabled": true
      },
      "default_arguments": {
        "--demo_owner": "data-engineering",
        "--demo_table": "tabla_demo_parametros"
      }
    }
  },
  "athena": {
    "ybwds_copa_brz": {
      "enabled": true,
      "enabled_environments": ["dev"],
      "sql_path": "./src/sql/ybwds_copa_brz/create_table.sql",
      "database_key": "demo",
      "table_name": "ybwds_copa_brz",
      "merge_existing": false,
      "environment_values": {
        "dev": {
          "s3_location": "s3://bronze-1358-0891-8691/COMERCIAL/ybwds_copa_brz/",
          "parameters": {
            "storage.location.template": "s3://bronze-1358-0891-8691/COMERCIAL/ybwds_copa_brz/ingestion_date=${ingestion_date}/"
          }
        }
      }
    },
    "ybwds_copa_brz_iceberg": {
      "enabled": true,
      "enabled_environments": ["dev"],
      "sql_path": "./src/sql/ybwds_copa_brz/create_table_iceberg.sql",
      "database_key": "demo",
      "table_name": "ybwds_copa_brz_iceberg",
      "merge_existing": false,
      "environment_values": {
        "dev": {
          "s3_location": "s3://bronze-1358-0891-8691/COMERCIAL/ybwds_copa_brz/",
          "parameters": {
            "table_type": "ICEBERG",
            "format": "parquet",
            "write_compression": "snappy"
          }
        }
      }
    }
  },
  "lambda": {
    "demo": {
      "enabled": true,
      "enabled_environments": ["dev"],
      "function_name": "lambda-demo",
      "description": "Lambda demo para probar el módulo",
      "source_path": "./src/lambda",
      "handler": "main.handler",
      "runtime": "python3.11",
      "timeout": 30,
      "memory_size": 256
    }
  }
}
